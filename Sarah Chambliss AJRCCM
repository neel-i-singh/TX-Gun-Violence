## Calculating weighted summary stats

```{r Table E1}
pop_pollution_long <- ATXMSA_model_data %>% 
  st_drop_geometry() %>% 
  #filter(COUNTYFP == "453") %>% 
  dplyr::select(c("GEOID", no2:co)) %>% 
  pivot_longer(cols = no2:co, names_to = "pollutant", values_to = "concentration") %>% 
  left_join(., ATXMSA_model_data %>% 
              st_drop_geometry() %>% 
              dplyr::select(c("GEOID",total:pop_latinx,pop_other)),
            by = "GEOID") %>% 
  pivot_longer(cols = total:pop_other, names_to = "population", values_to = "weight")

pop_pollution_summary <- pop_pollution_long %>% 
  group_by(pollutant, population) %>% 
  dplyr::summarise(means = weighted.mean(x=concentration,w=weight),
            medians = weighted.median(x=concentration,w=weight),
            lowerdec = weighted.quantile(x=concentration,w=weight,probs = .10),
            upperdec = weighted.quantile(x=concentration,w=weight,probs = .90),
            weighted_sd = sqrt(wtd.var(x=concentration,weights=weight))) 
