##CARBayes model runs: Specify and execute model

#### Select population (full, pediatric, adult) and formula
```{r }
numCores <- detectCores()
IRR_holder <- list()
Moran_holder <- list()
beta_samples_holder <- list()

```


```{r set parameters}
##This step specifies total, adult, or pediatric population
alt_model_set <- spatial_test %>% 
  mutate(ED_target = ED_adu_wbl, #ED_wbl, ED_ped_wbl, ED_adu_wbl 
         pop_offset = log(pop_adu_wbl)) #pop_wbl, pop_ped_wbl, pop_adu_wbl

longer_chain_factor = 1
spat_mod_option = F
model_family_option = "poisson" #"poisson" or "gaussian"
# model_num <- 9

for(model_num in 1:4){
  formalt <- poiss_forms[[model_num]] #poiss_forms[[model_num]] #poiss_forms or gauss_forms
  #### Define CARBayes function to run within parallel command
  ##### r set up parallel CARleroux runs}
  form_terms <- attr(terms(formalt), which = "term.labels")
  irr_range <- 2:(length(form_terms) + 1)
  
  if(spat_mod_option == T){
    fx <- function(iter = iter){
    chain_out <- S.CARleroux(formula = formalt,
                          data = alt_model_set,
                          family = model_family_option,
                          W = W,
                          burnin = 20000*longer_chain_factor,
                          n.sample = 100000*longer_chain_factor,
                          thin = 100*longer_chain_factor,
                          verbose = T)
    chain_out
    }
  }else{
  ## alternative: run with glm
    fx <- function(iter = iter){
    chain_out <- S.glm(formula = formalt,
                          data = alt_model_set,
                          family = model_family_option,
                          burnin = 20000*longer_chain_factor,
                          n.sample = 100000*longer_chain_factor,
                          thin = 100*longer_chain_factor,
                          verbose = T)
    chain_out
    }
  }
  
  #### Run 8 chains in parallel
  system.time(
    chain_list <- mclapply(1:8, fx, mc.cores = numCores)
  )
  
  #### Check the convergence of all of the chains together
  # beta is the intercept estimate.
  beta_samples <- mcmc.list(chain_list[[1]]$samples$beta, 
                            chain_list[[2]]$samples$beta, 
                            chain_list[[3]]$samples$beta,
                            chain_list[[4]]$samples$beta, 
                            chain_list[[5]]$samples$beta, 
                            chain_list[[6]]$samples$beta,
                            chain_list[[7]]$samples$beta, 
                            chain_list[[8]]$samples$beta)
  beta_samples_holder[[model_num]] <- beta_samples
  gelman.diag(beta_samples)
  # plot(beta_samples)
  
  if(spat_mod_option == T){
  # tau2 is conditional variance of the spatial random effect
  tau2_samples <- mcmc.list(chain_list[[1]]$samples$tau2, 
                            chain_list[[2]]$samples$tau2, 
                            chain_list[[3]]$samples$tau2,
                            chain_list[[4]]$samples$tau2, 
                            chain_list[[5]]$samples$tau2, 
                            chain_list[[6]]$samples$tau2,
                            chain_list[[7]]$samples$tau2, 
                            chain_list[[8]]$samples$tau2)
  
  # rho is a measure of the strength of spatial correlation, rho=1 means very strong spatial relationship, rho=0 means independence (no spatial).
  rho_samples <- mcmc.list(chain_list[[1]]$samples$rho, 
                           chain_list[[2]]$samples$rho, 
                           chain_list[[3]]$samples$rho,
                           chain_list[[4]]$samples$rho, 
                           chain_list[[5]]$samples$rho, 
                           chain_list[[6]]$samples$rho,
                           chain_list[[7]]$samples$rho, 
                           chain_list[[8]]$samples$rho)
  # print(gelman.diag(tau2_samples))
  # print(gelman.diag(rho_samples))
  # 
  # plot(tau2_samples)
  # plot(rho_samples)
  }
  
  ### Record Incidence Risk Ratios
  beta.samples.matrix0 <- rbind(chain_list[[1]]$samples$beta, 
                                chain_list[[2]]$samples$beta,
                                chain_list[[3]]$samples$beta,
                                chain_list[[4]]$samples$beta, 
                                chain_list[[5]]$samples$beta,
                                chain_list[[6]]$samples$beta,
                                chain_list[[7]]$samples$beta, 
                                chain_list[[8]]$samples$beta)
  colnames(beta.samples.matrix0) <- colnames(chain_list[[1]]$X)
  combined_betas <- round(t(apply(beta.samples.matrix0, 2, quantile, c(.5, .025, .975))),3)
  IRR <- exp((combined_betas[irr_range,]))
  
  IRR_holder[[model_num]] <- IRR
  
  # combined_betas
  
  
  # check for spatial pattern in residuals}
  fitted.samples.matrix <- rbind(chain_list[[1]]$samples$fitted, 
        chain_list[[2]]$samples$fitted,
        chain_list[[3]]$samples$fitted,
        chain_list[[4]]$samples$fitted, 
        chain_list[[5]]$samples$fitted,
        chain_list[[6]]$samples$fitted,
        chain_list[[7]]$samples$fitted, 
        chain_list[[8]]$samples$fitted)
  combined_fitted <- apply(fitted.samples.matrix, 2, quantile, c(.5))
  
  alt_model_set$residuals <- alt_model_set$ED_target - combined_fitted
  # alt_model_set$residuals <- alt_model_set$pm25 - combined_fitted
  
  
  # resid_map <- ggmap(ATX_bkgdmap) +
  #     geom_sf(data = alt_model_set %>%
  #               st_transform(st_crs(4326)),
  #             inherit.aes = F, aes(fill = residuals),
  #           alpha = .7, lwd = 0.1, color = NA) +
  #     scale_fill_viridis(direction = -1) +
  #   theme(axis.text = element_blank(),
  #         axis.ticks = element_blank(),
  #         axis.title = element_blank())
  # resid_map
  
  Moran_holder[[model_num]] <- moran.mc(x = alt_model_set$residuals, listw = W.list, nsim = 5000)
}
