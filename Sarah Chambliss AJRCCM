##CARBayes model runs: Setup

### Set up adjacency matrix
```{r transform vars and make adjacency W}
spatial_test <- ATXMSA_model_data %>% 
 filter(!is.na(no_vehicle) & pop_black != 0 & pop_adu_wbl > 0 & pop_ped_wbl > 0) %>% 
  # filter(!is.na(no_vehicle) & pop_black != 0 & COUNTYFP == "453") %>% 
  mutate(no2_u = no2,
         o3_u = o3,
         pm10_u = pm10,
         pm25_u = pm25,
         so2_u = so2,
         co_u = co,
         no2 = (no2 - mean(no2))/sd(no2),
         o3 = (o3 - mean(o3))/sd(o3),
         pm10 = (pm10 - mean(pm10))/sd(pm10),
         pm25 = (pm25 - mean(pm25))/sd(pm25),
         so2 = (so2 - mean(so2))/sd(so2),
         co = (co - mean(co))/sd(co),
         poverty = poverty * 10,
         no_vehicle = no_vehicle * 10,
         less_than_HS = less_than_HS * 10,
         gas_heating = gas_heating * 10,
         crowding = crowding * 10,
         attached_10 = attached_10 * 10,
         less2_bed = less2_bed * 10,
         share_hispanic = share_hispanic * 10,
         share_blacknh = share_blacknh * 10)
no_nb_check <- poly2nb(spatial_test, row.names = spatial_test$GEOID, queen = TRUE)
spatial_test = subset(spatial_test, subset = card(no_nb_check) > 0)
W.nb <- poly2nb(spatial_test, row.names = spatial_test$GEOID, queen = TRUE)
W.list <- nb2listw(W.nb, style = "B")
W <- nb2mat(W.nb, style="B")
```

